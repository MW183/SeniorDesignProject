{
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "[typescriptreact]": {
    "editor.quickSuggestions": {
      "strings": "on"
    }
  },
  "tailwindCSS.hovers": true,
  "tailwindCSS.codeActions": true,
  "tailwindCSS.classAttributes": [
    "className"
  ],
  "tailwindCSS.classFunctions": [
    "cva", "cn", "clsx", "twMerge"
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.experimental.configFile": "client/src/index.css",
  "tailwindCSS.includeLanguages": {
    "typscript": "html",
    "typscriptreact": "html"
  }
}
